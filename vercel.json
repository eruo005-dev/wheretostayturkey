{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build.js",
  "outputDirectory": "site",
  "framework": null,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:svg|png|jpg|jpeg|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com https://emrldtp.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; frame-src https://www.google.com https://googleads.g.doubleclick.net https://tpc.googlesyndication.com; connect-src 'self' https://assets.mailerlite.com https://pagead2.googlesyndication.com https://googleads.g.doubleclick.net; form-action 'self' https://assets.mailerlite.com; base-uri 'self'; object-src 'none'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/((?!thank-you|404).*)",
      "headers": [
        { "key": "Link", "value": "</assets/css/styles.css>; rel=preload; as=style; fetchpriority=high, <https://fonts.googleapis.com>; rel=preconnect, <https://fonts.gstatic.com>; rel=preconnect; crossorigin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/safety", "destination": "/is-turkey-safe/", "permanent": true },
    { "source": "/safety/", "destination": "/is-turkey-safe/", "permanent": true },
    { "source": "/transport-istanbul-cappadocia", "destination": "/istanbul-to-cappadocia/", "permanent": true },
    { "source": "/transport-istanbul-cappadocia/", "destination": "/istanbul-to-cappadocia/", "permanent": true },
    { "source": "/oludeniz", "destination": "/fethiye/", "permanent": true },
    { "source": "/oludeniz/", "destination": "/fethiye/", "permanent": true },
    { "source": "/cesme", "destination": "/izmir/", "permanent": true },
    { "source": "/cesme/", "destination": "/izmir/", "permanent": true },
    { "source": "/tours", "destination": "/experiences/", "permanent": true },
    { "source": "/tours/", "destination": "/experiences/", "permanent": true },
    { "source": "/cities-extras/black-sea", "destination": "/regions/black-sea/", "permanent": true },
    { "source": "/cities-extras/black-sea/", "destination": "/regions/black-sea/", "permanent": true },
    { "source": "/experiences/cay-as-currency/", "destination": "/culture/cay-as-currency/", "permanent": true },
    { "source": "/experiences/imece-collective-work/", "destination": "/culture/imece-collective-work/", "permanent": true },
    { "source": "/experiences/kolay-gelsin-the-everyday-blessing/", "destination": "/culture/kolay-gelsin-the-everyday-blessing/", "permanent": true },
    { "source": "/experiences/mahalle-the-turkish-neighborhood/", "destination": "/culture/mahalle-the-turkish-neighborhood/", "permanent": true },
    { "source": "/experiences/misafirperverlik-turkish-hospitality/", "destination": "/culture/misafirperverlik-turkish-hospitality/", "permanent": true }
  ]
}
